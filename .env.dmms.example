# DMMS Environment Configuration
# Copy this file to .env.dmms and fill in your values

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
DMMS_JWT_SECRET=your-secret-here

# Server port (default: 3005)
DMMS_PORT=3005

# MySQL database connection
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dmms
DB_USERNAME=root
DB_PASSWORD=your-db-password-here
